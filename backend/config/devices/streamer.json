{
  "names": {
    "ru": "Стример",
    "en": "Streamer"
  },
  "device_id": "streamer",
  "room": "living_room",
  "alias": "streamer",
  "device_class": "AuralicDevice",
  "config_class": "AuralicDeviceConfig",
  "auralic": {
    "ip_address": "192.168.110.142",
    "update_interval": 15,
    "discovery_mode": true,
    "device_url": null,
    "device_boot_time": 20
  },
  "commands": {
    "power_on": {
      "action": "power_on",
      "description": "Power On"
    },
    "power_off": {
      "action": "power_off",
      "description": "Power Off",
      "params": [
        {
          "name": "standby_only",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "If true, only put the device in standby mode instead of true power off"
        }
      ]
    },
    "play": {
      "action": "play",
      "description": "Play"
    },
    "pause": {
      "action": "pause",
      "description": "Pause"
    },
    "stop": {
      "action": "stop",
      "description": "Stop"
    },
    "next": {
      "action": "next",
      "description": "Next Track"
    },
    "set_volume": {
      "action": "set_volume",
      "description": "Set Volume",
      "params": [
        {
          "name": "volume",
          "type": "range",
          "min": 0,
          "max": 100,
          "required": true,
          "description": "Volume level (0-100)"
        }
      ]
    },
    "volume_up": {
      "action": "volume_up",
      "description": "Increase Volume"
    },
    "volume_down": {
      "action": "volume_down",
      "description": "Decrease Volume"
    },
    "mute": {
      "action": "mute",
      "description": "Toggle Mute"
    },
    "set_input": {
      "action": "set_input",
      "description": "Set Input",
      "params": [
        {
          "name": "input",
          "type": "string",
          "required": true,
          "description": "Input name or index"
        }
      ]
    },
    "track_info": {
      "action": "track_info",
      "description": "Get Current Track Information",
      "exposed": false
    },
    "get_available_inputs": {
      "action": "get_available_inputs",
      "description": "List available inputs"
    },
    "refresh_inputs": {
      "action": "refresh_inputs",
      "description": "Refresh inputs list",
      "exposed": false
    }
  }
}