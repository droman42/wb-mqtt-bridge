{
  "alias": "processor",
  "device_id": "processor",
  "room": "living_room",
  "names": {
    "ru": "Процессор",
    "en": "AV Processor"
  },
  "device_class": "EMotivaXMC2",
  "config_class": "EmotivaXMC2DeviceConfig",
  "emotiva": {
    "host": "192.168.110.177",
    "mac": "E8:EB:1B:18:8F:3E",
    "port": 7002,
    "update_interval": 60
  },
  "commands": {
    "power_on": {
      "action": "power_on",
      "description": "Turn on the processor",
      "params": [
        {
          "name": "zone",
          "type": "integer",
          "required": true,
          "default": 1,
          "min": 1,
          "max": 2,
          "description": "Zone ID (1 for main, 2 for zone2)"
        }
      ]
    },
    "power_off": {
      "action": "power_off",
      "description": "Turn off the processor",
      "params": [
        {
          "name": "zone",
          "type": "integer",
          "required": true,
          "default": 1,
          "min": 1,
          "max": 2,
          "description": "Zone ID (1 for main, 2 for zone2)"
        }
      ]
    },
    "zone2_power_toggle": {
      "action": "zone2_power_toggle",
      "description": "Toggle Zone 2 power"
    },
    "set_input": {
      "action": "set_input",
      "description": "Select logical source (Input button)",
      "params": [
        {
          "name": "input",
          "type": "string",
          "required": true,
          "default": "source1",
          "description": "Logical source / Input button (source1-source8)"
        }
      ]
    },
    "set_volume": {
      "action": "set_volume",
      "description": "Set the volume level",
      "params": [
        {
          "name": "level",
          "type": "range",
          "min": -96.0,
          "max": 0.0,
          "required": true,
          "description": "Volume level in dB (-96.0 to 0.0)",
          "units": "dB"
        },
        {
          "name": "zone",
          "type": "integer",
          "required": true,
          "default": 1,
          "min": 1,
          "max": 2,
          "description": "Zone ID (1 for main, 2 for zone2)"
        }
      ]
    },
    "mute_toggle": {
      "action": "mute_toggle",
      "description": "Toggle mute state",
      "params": [
        {
          "name": "zone",
          "type": "integer",
          "required": true,
          "default": 1,
          "min": 1,
          "max": 2,
          "description": "Zone ID (1 for main, 2 for zone2)"
        }
      ]
    },
    "get_available_inputs": {
      "action": "get_available_inputs",
      "description": "List available inputs"
    }
  }
}
