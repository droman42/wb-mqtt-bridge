{
  "device_id": "living_room_hvac",
  "device_class": "WbPassthroughDevice",
  "config_class": "WbPassthroughDeviceConfig",
  "names": {
    "ru": "Кондиционер",
    "en": "Air Conditioner",
    "de": "Klimaanlage"
  },
  "capability_profile": "hvac",
  "room": "living_room",
  "commands": {
    "power_on": {
      "topic": "/devices/hvac_livingroom/controls/power/on",
      "value": "1"
    },
    "power_off": {
      "topic": "/devices/hvac_livingroom/controls/power/on",
      "value": "0"
    },
    "set_mode": {
      "topic": "/devices/hvac_livingroom/controls/mode/on",
      "params": [
        {
          "name": "mode",
          "type": "string",
          "required": true
        }
      ]
    },
    "set_fan": {
      "topic": "/devices/hvac_livingroom/controls/fan/on",
      "params": [
        {
          "name": "speed",
          "type": "string",
          "required": true
        }
      ]
    },
    "set_vane": {
      "topic": "/devices/hvac_livingroom/controls/vane/on",
      "params": [
        {
          "name": "angle",
          "type": "string",
          "required": true
        }
      ]
    },
    "set_widevane": {
      "topic": "/devices/hvac_livingroom/controls/widevane/on",
      "params": [
        {
          "name": "direction",
          "type": "string",
          "required": true
        }
      ]
    },
    "set_setpoint": {
      "topic": "/devices/hvac_livingroom/controls/temperature/on",
      "params": [
        {
          "name": "temp",
          "type": "float",
          "min": 16,
          "max": 31,
          "required": true,
          "units": "°C"
        }
      ]
    }
  },
  "state_topics": {
    "power": "/devices/hvac_livingroom/controls/power",
    "mode": {
      "topic": "/devices/hvac_livingroom/controls/mode",
      "type": "enum",
      "values": [
        {
          "wire": "0",
          "canonical": "auto"
        },
        {
          "wire": "1",
          "canonical": "dry"
        },
        {
          "wire": "2",
          "canonical": "cool"
        },
        {
          "wire": "3",
          "canonical": "heat"
        },
        {
          "wire": "4",
          "canonical": "fan_only"
        }
      ]
    },
    "fan": {
      "topic": "/devices/hvac_livingroom/controls/fan",
      "type": "enum",
      "values": [
        {
          "wire": "0",
          "canonical": "auto"
        },
        {
          "wire": "1",
          "canonical": "quiet"
        },
        {
          "wire": "2",
          "canonical": "speed_1"
        },
        {
          "wire": "3",
          "canonical": "speed_2"
        },
        {
          "wire": "4",
          "canonical": "speed_3"
        },
        {
          "wire": "5",
          "canonical": "speed_4"
        }
      ]
    },
    "vane": {
      "topic": "/devices/hvac_livingroom/controls/vane",
      "type": "enum",
      "values": [
        {
          "wire": "0",
          "canonical": "auto"
        },
        {
          "wire": "1",
          "canonical": "swing"
        },
        {
          "wire": "2",
          "canonical": "pos_1"
        },
        {
          "wire": "3",
          "canonical": "pos_2"
        },
        {
          "wire": "4",
          "canonical": "pos_3"
        },
        {
          "wire": "5",
          "canonical": "pos_4"
        },
        {
          "wire": "6",
          "canonical": "pos_5"
        }
      ]
    },
    "widevane": {
      "topic": "/devices/hvac_livingroom/controls/widevane",
      "type": "enum",
      "values": [
        {
          "wire": "0",
          "canonical": "swing"
        },
        {
          "wire": "1",
          "canonical": "far_left"
        },
        {
          "wire": "2",
          "canonical": "left"
        },
        {
          "wire": "3",
          "canonical": "center"
        },
        {
          "wire": "4",
          "canonical": "right"
        },
        {
          "wire": "5",
          "canonical": "far_right"
        },
        {
          "wire": "6",
          "canonical": "split"
        }
      ]
    },
    "temperature": {
      "topic": "/devices/hvac_livingroom/controls/temperature",
      "type": "float",
      "unit": "°C"
    },
    "room_temperature": {
      "topic": "/devices/hvac_livingroom/controls/room_temperature",
      "type": "float",
      "unit": "°C"
    }
  },
  "aliases": {
    "ru": [
      "кондей"
    ]
  }
}
