{
  "climate": {
    "kind": "stateful",
    "feedback": true,
    "state_field": "power",
    "actions": {
      "on":           { "command": "power_on" },
      "off":          { "command": "power_off" },
      "set_mode":     { "command": "set_mode",     "param_map": { "mode": "mode" } },
      "set_fan":      { "command": "set_fan",      "param_map": { "fan": "speed" } },
      "set_vane":     { "command": "set_vane",     "param_map": { "vane": "angle" } },
      "set_widevane": { "command": "set_widevane", "param_map": { "widevane": "direction" } },
      "set_setpoint": { "command": "set_setpoint", "param_map": { "temp": "temp" } }
    },
    "fields": [
      { "name": "temperature", "type": "float", "unit": "°C",
        "labels": { "ru": "уставка", "en": "setpoint", "de": "Sollwert" } },
      { "name": "room_temperature", "type": "float", "unit": "°C",
        "labels": { "ru": "температура в комнате", "en": "room temperature", "de": "Raumtemperatur" } },
      { "name": "mode", "type": "enum",
        "labels": { "ru": "режим", "en": "mode", "de": "Modus" },
        "values": [
          { "wire": "AUTO", "canonical": "auto",     "labels": { "ru": "авто",       "en": "auto", "de": "Automatik"   } },
          { "wire": "DRY",  "canonical": "dry",      "labels": { "ru": "осушение",   "en": "dry",  "de": "Entfeuchten" } },
          { "wire": "COOL", "canonical": "cool",     "labels": { "ru": "охлаждение", "en": "cool", "de": "Kühlen"      } },
          { "wire": "HEAT", "canonical": "heat",     "labels": { "ru": "обогрев",    "en": "heat", "de": "Heizen"      } },
          { "wire": "FAN",  "canonical": "fan_only", "labels": { "ru": "вентилятор", "en": "fan",  "de": "Lüften"      } }
        ]
      },
      { "name": "fan", "type": "enum",
        "labels": { "ru": "вентилятор", "en": "fan", "de": "Lüfter" },
        "values": [
          { "wire": "AUTO",  "canonical": "auto",    "labels": { "ru": "авто",       "en": "auto",    "de": "Automatik" } },
          { "wire": "QUIET", "canonical": "quiet",   "labels": { "ru": "тихий",      "en": "quiet",   "de": "Leise"     } },
          { "wire": "1",     "canonical": "speed_1", "labels": { "ru": "скорость 1", "en": "speed 1", "de": "Stufe 1"   } },
          { "wire": "2",     "canonical": "speed_2", "labels": { "ru": "скорость 2", "en": "speed 2", "de": "Stufe 2"   } },
          { "wire": "3",     "canonical": "speed_3", "labels": { "ru": "скорость 3", "en": "speed 3", "de": "Stufe 3"   } },
          { "wire": "4",     "canonical": "speed_4", "labels": { "ru": "скорость 4", "en": "speed 4", "de": "Stufe 4"   } }
        ]
      },
      { "name": "vane", "type": "enum",
        "labels": { "ru": "жалюзи", "en": "vane", "de": "Lamelle" },
        "values": [
          { "wire": "AUTO",  "canonical": "auto",  "labels": { "ru": "авто",        "en": "auto",       "de": "Automatik"  } },
          { "wire": "SWING", "canonical": "swing", "labels": { "ru": "качание",     "en": "swing",      "de": "Schwingen"  } },
          { "wire": "1",     "canonical": "pos_1", "labels": { "ru": "положение 1", "en": "position 1", "de": "Position 1" } },
          { "wire": "2",     "canonical": "pos_2", "labels": { "ru": "положение 2", "en": "position 2", "de": "Position 2" } },
          { "wire": "3",     "canonical": "pos_3", "labels": { "ru": "положение 3", "en": "position 3", "de": "Position 3" } },
          { "wire": "4",     "canonical": "pos_4", "labels": { "ru": "положение 4", "en": "position 4", "de": "Position 4" } },
          { "wire": "5",     "canonical": "pos_5", "labels": { "ru": "положение 5", "en": "position 5", "de": "Position 5" } }
        ]
      },
      { "name": "widevane", "type": "enum",
        "labels": { "ru": "горизонтальные жалюзи", "en": "wide vane", "de": "Horizontallamelle" },
        "values": [
          { "wire": "SWING", "canonical": "swing",     "labels": { "ru": "качание",       "en": "swing",     "de": "Schwingen"   } },
          { "wire": "<<",    "canonical": "far_left",  "labels": { "ru": "крайне влево",  "en": "far left",  "de": "ganz links"  } },
          { "wire": "<",     "canonical": "left",      "labels": { "ru": "влево",         "en": "left",      "de": "links"       } },
          { "wire": "|",     "canonical": "center",    "labels": { "ru": "центр",         "en": "center",    "de": "Mitte"       } },
          { "wire": ">",     "canonical": "right",     "labels": { "ru": "вправо",        "en": "right",     "de": "rechts"      } },
          { "wire": ">>",    "canonical": "far_right", "labels": { "ru": "крайне вправо", "en": "far right", "de": "ganz rechts" } },
          { "wire": "<>",    "canonical": "split",     "labels": { "ru": "разделено",     "en": "split",     "de": "geteilt"     } }
        ]
      }
    ]
  }
}
