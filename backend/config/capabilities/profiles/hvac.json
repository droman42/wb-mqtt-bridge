{
  "climate": {
    "kind": "stateful",
    "feedback": true,
    "state_field": "power",
    "actions": {
      "on":           { "command": "power_on" },
      "off":          { "command": "power_off" },
      "set_mode":     { "command": "set_mode",     "param_map": { "mode": "mode" } },
      "set_fan":      { "command": "set_fan",      "param_map": { "speed": "speed" } },
      "set_vane":     { "command": "set_vane",     "param_map": { "angle": "angle" } },
      "set_widevane": { "command": "set_widevane", "param_map": { "direction": "direction" } },
      "set_setpoint": { "command": "set_setpoint", "param_map": { "temp": "temp" } }
    },
    "fields": [
      { "name": "temperature", "type": "float", "unit": "°C",
        "labels": { "ru": "уставка", "en": "setpoint", "de": "Sollwert" } },
      { "name": "room_temperature", "type": "float", "unit": "°C",
        "labels": { "ru": "температура в комнате", "en": "room temperature", "de": "Raumtemperatur" } }
    ]
  }
}
