{
  "power": {
    "kind": "stateful", "feedback": true, "state_field": "power", "on_value": "on",
    "actions": { "on": { "command": "power_on" }, "off": { "command": "power_off" } },
    "gate": { "poll_timeout_ms": 8000 }
  },
  "input": {
    "kind": "stateful", "feedback": true, "state_field": "input_source",
    "select": { "command": "set_input_source", "param_map": { "input": "source" } },
    "list": { "command": "get_available_inputs" },
    "gate": { "poll_timeout_ms": 3000 },
    "source_modes": ["arc"]
  },
  "volume": {
    "kind": "momentary",
    "state_field": "volume",
    "actions": {
      "up": { "command": "volume_up" },
      "down": { "command": "volume_down" },
      "set": { "command": "set_volume", "param_map": { "level": "level" } },
      "mute_toggle": { "command": "mute" }
    }
  },
  "menu": {
    "kind": "momentary",
    "actions": {
      "up": { "command": "up" },
      "down": { "command": "down" },
      "left": { "command": "left" },
      "right": { "command": "right" },
      "ok": { "command": "enter" },
      "back": { "command": "back" },
      "home": { "command": "home" },
      "menu": { "command": "menu" },
      "exit": { "command": "exit" }
    }
  },
  "playback": {
    "kind": "momentary",
    "actions": {
      "play": { "command": "play" },
      "pause": { "command": "pause" },
      "stop": { "command": "stop" },
      "ff": { "command": "rewind_forward" },
      "rewind": { "command": "rewind_backward" }
    }
  },
  "apps": {
    "kind": "momentary",
    "actions": { "launch": { "command": "launch_app", "param_map": { "app": "app_name" } } },
    "list": { "command": "get_available_apps" }
  },
  "pointer": {
    "kind": "momentary",
    "actions": {
      "move": { "command": "move_cursor_relative", "param_map": { "dx": "dx", "dy": "dy" } },
      "click": { "command": "click" }
    }
  }
}
