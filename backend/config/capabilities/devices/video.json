{
  "power": {
    "kind": "stateful", "feedback": false, "state_field": "power", "on_value": "on",
    "actions": { "on": { "command": "power_on" }, "off": { "command": "power_off" } },
    "gate": { "delay_ms": 1000 }
  },
  "playback": {
    "kind": "momentary",
    "actions": {
      "play_pause": { "command": "play_pause" },
      "stop": { "command": "stop" },
      "next": { "command": "chapter_plus" },
      "previous": { "command": "chapter_minus" }
    }
  },
  "menu": {
    "kind": "momentary",
    "actions": {
      "up": { "command": "menu_up" },
      "down": { "command": "menu_down" },
      "left": { "command": "menu_left" },
      "right": { "command": "menu_right" },
      "ok": { "command": "menu_ok" },
      "home": { "command": "home" },
      "back": { "command": "back" },
      "settings": { "command": "settings" }
    }
  },
  "tracks": {
    "kind": "momentary",
    "actions": {
      "audio": { "command": "audio" },
      "subtitles": { "command": "subtitles" }
    }
  }
}
