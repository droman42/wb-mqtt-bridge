{
  "name": "@locveil/bridge-workbench-plugin",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "description": "The Bridge plugin for the Locveil Workbench shell (HK-11 runtime assembly).",
  "scripts": {
    "build": "tsc && vite build",
    "typecheck": "tsc",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "check": "npm run typecheck && npm run lint",
    "gen:api-types": "openapi-typescript ${OPENAPI_SCHEMA:-../backend/openapi.json} -o src/types/openapi.gen.ts"
  },
  "dependencies": {
    "locveil-ui-kit": "file:../../locveil-commons/packages/ui-kit",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^15.9.0",
    "locveil-workbench": "file:../../locveil-commons/packages/workbench",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3"
  }
}
