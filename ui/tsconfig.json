{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    
    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules", 
    "dist", 
    "**/*.d.ts", 
    "src/**/*.gen.tsx",
    "src/scripts/**/*",
    "src/lib/validation/**/*",
    "src/lib/BatchProcessor.ts",
    "src/lib/DataValidator.ts",
    "src/lib/DeviceConfigurationClient.ts",
    "src/lib/DocumentationGenerator.ts",
    "src/lib/ErrorHandler.ts",
    "src/lib/PerformanceMonitor.ts",
    "src/lib/StateTypeGenerator.ts",
    "src/lib/deviceHandlers/**/*",
    "src/lib/generators/**/*",
    "src/lib/integration/**/*"
  ]
} 