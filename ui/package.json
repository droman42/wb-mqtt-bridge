{
  "name": "smart-home-ui-v2",
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "gen:api-types": "openapi-typescript ${OPENAPI_SCHEMA:-../backend/openapi.json} -o src/types/openapi.gen.ts",
    "preview": "vite preview",
    "test": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "npm run typecheck",
    "check:orphans": "node scripts/find-orphans.mjs",
    "check": "npm run typecheck:all && npm run lint && npm run check:orphans",
    "gen:favicon": "node scripts/generate-favicon.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "i18next": "^23.5.0",
    "immer": "^10.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.2.0",
    "react-router-dom": "^6.30.4",
    "tailwind-merge": "^1.14.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^13.4.0",
    "@types/node": "^20.5.0",
    "@eslint/js": "^9.39.5",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.12.0",
    "autoprefixer": "^10.4.15",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "glob": "^10.3.0",
    "globals": "^17.7.0",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^29.6.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.55.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.3.3",
    "tsx": "^4.19.4",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "yaml": "^2.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
