#!/bin/sh
# Locveil pre-commit hook (locveil-commons/process/ledger-discipline.md §4): the
# scope-guard check only — hooks never mutate the tree. With work-on-main this is
# the only pre-CI gate. Install once:  git config core.hooksPath hooks
exec python3 scripts/scope_guard.py --config .scope-guard.toml
