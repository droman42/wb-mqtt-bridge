{
  "device_id": "bedroom_shelves_light",
  "device_class": "WbPassthroughDevice",
  "config_class": "WbPassthroughDeviceConfig",
  "names": {
    "ru": "Подсветка полок",
    "en": "Shelves Accent",
    "de": "Regalbeleuchtung"
  },
  "capability_profile": "dimmable_light",
  "room": "bedroom",
  "commands": {
    "power_on": {
      "topic": "/devices/wb-mrgbw-d-fw3_10/controls/Channel 1 (B)/on",
      "value": "1"
    },
    "power_off": {
      "topic": "/devices/wb-mrgbw-d-fw3_10/controls/Channel 1 (B)/on",
      "value": "0"
    },
    "set_brightness": {
      "topic": "/devices/wb-mrgbw-d-fw3_10/controls/Channel 1 (B) Brightness/on",
      "params": [
        {
          "name": "level",
          "type": "range",
          "min": 0,
          "max": 100,
          "required": true,
          "units": "%"
        }
      ]
    }
  },
  "state_topics": {
    "power": "/devices/wb-mrgbw-d-fw3_10/controls/Channel 1 (B)",
    "level": {
      "topic": "/devices/wb-mrgbw-d-fw3_10/controls/Channel 1 (B) Brightness",
      "type": "int",
      "unit": "%"
    }
  }
}
