{
  "device_id": "living_room_heating",
  "device_class": "WbPassthroughDevice",
  "config_class": "WbPassthroughDeviceConfig",
  "names": {
    "ru": "Обогрев",
    "en": "Heating",
    "de": "Heizung"
  },
  "capability_profile": "heating_loop",
  "room": "living_room",
  "commands": {
    "mode_on": {
      "topic": "/devices/wb-gpio/controls/EXT3_R3A2/on",
      "value": "1"
    },
    "mode_off": {
      "topic": "/devices/wb-gpio/controls/EXT3_R3A2/on",
      "value": "0"
    },
    "set_setpoint": {
      "topic": "/devices/setpoints_radiator/controls/livingroom_temp/on",
      "params": [
        {
          "name": "temp",
          "type": "float",
          "min": 5,
          "max": 30,
          "required": true,
          "units": "°C"
        }
      ]
    }
  },
  "state_topics": {
    "mode": {
      "topic": "/devices/wb-gpio/controls/EXT3_R3A2",
      "type": "bool",
      "invert": true
    },
    "setpoint": {
      "topic": "/devices/setpoints_radiator/controls/livingroom_temp",
      "type": "float",
      "unit": "°C"
    },
    "room_temperature": {
      "topic": "/devices/wb-msw-v3_207/controls/Temperature",
      "type": "float",
      "unit": "°C"
    }
  },
  "aliases": {
    "ru": [
      "радиаторы"
    ]
  }
}
