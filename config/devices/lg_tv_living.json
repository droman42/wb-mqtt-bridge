{
  "names": {
    "ru": "Телевизор",
    "en": "TV"
  },
  "device_id": "living_room_tv",
  "room": "living_room",
  "alias": "living_room_tv",
  "device_class": "LgTv",
  "config_class": "LgTvDeviceConfig",
  "tv": {
    "ip_address": "192.168.110.133",
    "broadcast_ip": "192.168.110.255",
    "mac_address": "74:E6:B8:9C:36:5F",
    "client_key": "a8d2f9a7845cdf406021d782551b4860",
    "secure": true,
    "cert_file": "config/devices/certs/living_cert.pem",
    "timeout": 20,
    "reconnect_interval": 60
  },
  "commands": {
    "power_on": {
      "action": "power_on",
      "description": "Power On"
    },
    "power_off": {
      "action": "power_off",
      "description": "Power Off"
    },
    "home": {
      "action": "home",
      "description": "Home"
    },
    "back": {
      "action": "back",
      "description": "Back"
    },
    "up": {
      "action": "up",
      "description": "Up"
    },
    "down": {
      "action": "down",
      "description": "Down"
    },
    "left": {
      "action": "left",
      "description": "Left"
    },
    "right": {
      "action": "right",
      "description": "Right"
    },
    "enter": {
      "action": "enter",
      "description": "Enter/OK"
    },
    "volume_up": {
      "action": "volume_up",
      "description": "Volume Up"
    },
    "volume_down": {
      "action": "volume_down",
      "description": "Volume Down"
    },
    "mute": {
      "action": "mute",
      "description": "Mute"
    },
    "play": {
      "action": "play",
      "description": "Play"
    },
    "pause": {
      "action": "pause",
      "description": "Pause"
    },
    "stop": {
      "action": "stop",
      "description": "Stop"
    },
    "rewind_forward": {
      "action": "rewind_forward",
      "description": "Fast Forward"
    },
    "rewind_backward": {
      "action": "rewind_backward",
      "description": "Fast Backward"
    },
    "exit": {
      "action": "exit",
      "description": "Exit Button"
    },
    "menu": {
      "action": "menu",
      "description": "Menu Button"
    },
    "set_volume": {
      "action": "set_volume",
      "description": "Set Volume Level",
      "params": [
        {
          "name": "level",
          "type": "range",
          "min": 0,
          "max": 100,
          "required": true,
          "description": "Volume level (0-100)"
        }
      ]
    },
    "move_cursor_relative": {
      "action": "move_cursor_relative",
      "description": "Move Cursor Relative",
      "params": [
        {
          "name": "dx",
          "type": "range",
          "min": -50,
          "max": 50,
          "required": true,
          "description": "X displacement (-50 to 50)"
        },
        {
          "name": "dy",
          "type": "range",
          "min": -50,
          "max": 50,
          "required": true,
          "description": "Y displacement (-50 to 50)"
        }
      ]
    },
    "click": {
      "action": "click",
      "description": "Click at current position"
    },
    "set_input_source": {
      "action": "set_input_source",
      "description": "Set Input Source",
      "params": [
        {
          "name": "source",
          "type": "string",
          "required": true,
          "description": "Input source name or ID (e.g., 'hdmi1', 'hdmi2')"
        }
      ]
    },
    "launch_app": {
      "action": "launch_app",
      "description": "Launch App",
      "params": [
        {
          "name": "app_name",
          "type": "string",
          "required": false,
          "description": "App name to launch (preferred, at least one of app_name or app_id must be provided)"
        },
        {
          "name": "app_id",
          "type": "string",
          "required": false,
          "description": "App ID to launch (alternative, at least one of app_name or app_id must be provided)"
        }
      ]
    },
    "get_available_apps": {
      "action": "get_available_apps",
      "description": "List available Apps"
    },
    "get_available_inputs": {
      "action": "get_available_inputs",
      "description": "List available inputs"
    }
  },
  "aliases": {
    "ru": [
      "телек"
    ]
  }
}
