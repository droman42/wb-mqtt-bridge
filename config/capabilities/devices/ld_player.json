{
  "power": {
    "kind": "stateful", "feedback": false, "state_field": "power", "on_value": "on",
    "actions": { "toggle": { "command": "power" } },
    "gate": { "delay_ms": 1000 }
  },
  "playback": {
    "kind": "momentary",
    "actions": {
      "play": { "command": "play" },
      "pause": { "command": "pause" },
      "stop": { "command": "stop" },
      "next": { "command": "chapter_plus" },
      "previous": { "command": "chapter_minus" }
    }
  },
  "tracks": {
    "kind": "momentary",
    "actions": {
      "audio": { "command": "audio" },
      "eject": { "command": "tray" }
    }
  }
}
