{
  "_comment": "Signal topology for the living-room A/V system. Declared once; scenarios reference it. A link's destination port is the input value to select on the sink device. See docs/design/scenarios/scenario_system_redesign.md (Layer 0) and docs/design/ui_backend_contract.md.",
  "nodes": {
    "dodocus": {
      "kind": "manual",
      "name": "Dodocus RCA hub",
      "positions": {
        "ld": "Switch Dodocus to LD",
        "vhs": "Switch Dodocus to VHS",
        "reel": "Switch Dodocus to REEL",
        "tape": "Switch Dodocus to TAPE",
        "phono": "Switch Dodocus to LP"
      }
    },
    "b215": {
      "kind": "manual",
      "name": "Revox B215 tape deck"
    },
    "kuzma": {
      "kind": "manual",
      "name": "Kuzma Stabi S turntable"
    },
    "sugden_pa4": {
      "kind": "manual",
      "name": "Sugden Masterclass PA4 phono corrector",
      "positions": {
        "in": "Power on the Sugden PA-4"
      }
    }
  },
  "links": [
    {
      "from": "appletv_living:hdmi",
      "to": "processor:source2",
      "carries": [
        "video",
        "audio"
      ]
    },
    {
      "from": "ld_player:av",
      "to": "upscaler:video",
      "carries": [
        "video"
      ]
    },
    {
      "from": "vhs_player:av",
      "to": "upscaler:s_vhs",
      "carries": [
        "video"
      ]
    },
    {
      "from": "upscaler:out",
      "to": "processor:source3",
      "carries": [
        "video"
      ]
    },
    {
      "from": "video:hdmi",
      "to": "processor:source1",
      "carries": [
        "video",
        "audio"
      ]
    },
    {
      "from": "processor:hdmi_out",
      "to": "living_room_tv:hdmi2",
      "carries": [
        "video"
      ]
    },
    {
      "from": "living_room_tv:arc",
      "to": "processor:arc",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "processor:zone2",
      "to": "mf_amplifier:aux2",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "ld_player:audio",
      "to": "dodocus:ld",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "vhs_player:audio",
      "to": "dodocus:vhs",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "dodocus:out",
      "to": "mf_amplifier:cd",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "streamer:out",
      "to": "mf_amplifier:balanced",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "reel_to_reel:audio",
      "to": "dodocus:reel",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "b215:out",
      "to": "dodocus:tape",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "kuzma:out",
      "to": "sugden_pa4:in",
      "carries": [
        "audio"
      ]
    },
    {
      "from": "sugden_pa4:out",
      "to": "dodocus:phono",
      "carries": [
        "audio"
      ]
    }
  ],
  "ordering": [
    {
      "first": "living_room_tv.power",
      "then": "processor.power",
      "reason": "TV must be on before the eMotiva (ARC handshake)"
    },
    {
      "first": "processor.power",
      "then": "living_room_tv.input",
      "reason": "eMotiva on before TV switches to HDMI2, else ARC takes over the audio"
    },
    {
      "first": "living_room_tv.input",
      "then": "processor.input",
      "reason": "TV settles on HDMI2 before the eMotiva routes its input (HDMI-ARC)"
    },
    {
      "first": "processor.input",
      "then": "video.power",
      "reason": "Zappiti powers on only after the eMotiva has COMPLETED the HDMI switch to source1 — the ack is instant but physical routing takes seconds; booting into an unrouted sink loses the Zappiti's HDMI output until repower (known hardware quirk). 5 s settle; replace with a feedback-gated edge when SCN-10 lands.",
      "delay_ms": 5000
    },
    {
      "first": "ld_player.power",
      "then": "upscaler.input",
      "delay_ms": 4500,
      "reason": "upscaler auto-powers with the LD; give it ~4-5s before switching its input"
    },
    {
      "first": "vhs_player.power",
      "then": "upscaler.input",
      "delay_ms": 4500,
      "reason": "upscaler auto-powers with the VHS; give it ~4-5s before switching its input"
    }
  ]
}