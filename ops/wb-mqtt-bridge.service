# ops/wb-mqtt-bridge.service — systemd unit that runs the compose stack on
# Wirenboard boot. Replaces docker_manager's lifecycle management.
#
# Install (one-time, see ops/INSTALL.md for the full walkthrough):
#   sudo cp /mnt/data/mqtt-bridge-config/ops/wb-mqtt-bridge.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now wb-mqtt-bridge.service
#
# Adjust WorkingDirectory below if you cloned the repo to a different path.

[Unit]
Description=wb-mqtt-bridge (backend + UI via docker compose)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/mnt/data/mqtt-bridge-config/ops
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
# A failed pull or start shouldn't tear systemd's PID 1 down — let restart handle it.
TimeoutStartSec=300
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
