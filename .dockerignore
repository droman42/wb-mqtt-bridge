# Single build context for BOTH images since CORE-11: the backend
# (docker/Dockerfile.backend) and the UI (docker/Dockerfile.ui) are both built with
# context = monorepo root. Each Dockerfile copies only what it needs by explicit path
# (backend: backend/src + backend/pyproject.toml + backend/uv.lock; ui: ui/), so this
# file just keeps the context lean. Merged from the former backend/ and ui/ .dockerignores.

# Version control / CI / build recipes
.git
.github
docker

# Node / Python environments + caches
**/node_modules
**/.venv
venv/
env/
ENV/
**/__pycache__
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/.coverage
**/.tox

# Secrets + local env files (never bake into an image)
**/.env
**/.env.*
!**/.env.example

# State, logs, tests, build output
**/*.log
**/*.db
**/*.sqlite3
backend/logs
backend/data
backend/tests
ui/dist

# Product data (mounted at runtime, never baked in) + docs / ops / rules
config
docs
wb-rules
ops

# Editors / OS
**/.idea
**/.vscode
**/.DS_Store
ops/docker_manager_config.json
