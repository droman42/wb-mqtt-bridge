// wb-mqtt-bridge — planned voice-setup process. Render:
//   dot -Tpng docs/images/voice-setup.dot -o docs/images/voice-setup.png
// Palette: see hexagon.dot header.
digraph voice_setup {
  rankdir=LR;
  bgcolor="white";
  splines=spline;
  nodesep=0.45; ranksep=0.9;
  fontname="Helvetica"; labelloc=t; fontsize=16;
  label="wb-mqtt-bridge — voice-setup process: contract pillars + admin surface (most built, no setup page yet)";

  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  // --- contract pillars (bridge side) ---
  subgraph cluster_bridge {
    label="wb-mqtt-bridge — contract surface"; fontsize=12; color="#cfcfcf"; style=rounded; margin=12;

    pill_a [label="Pillar A: canonical action endpoint\nPOST /devices/{id}/canonical\n{capability, action, params}\n6-code error enum · 500 ms echo wait",
            fillcolor="#fff3e0", color="#ef6c00"];
    pill_b [label="Pillar B: voice-friendly catalog\nGET /system/catalog\nall locales · capability-shaped\nretained bridge/catalog/version (refresh nudge)",
            fillcolor="#fff3e0", color="#ef6c00"];
    pill_c [label="Pillar C: WB onboarding (the device fleet)\nWB-passthrough driver\n+ capability profiles\n+ 57 device configs across 10 rooms",
            fillcolor="#fff3e0", color="#ef6c00"];
    pending [shape=note, fillcolor="#fff8e1", color="#f57f17",
             label="still pending (§P3.7):\n#22 aggregate devices in `global` (all_lights, …)\n#24 wb-msw-v3 sensor side\n#25 catalog completeness sweep + bulk e2e\n#26 value-label translation layer"];
  }

  // --- the Irene side (sister project, shown for context) ---
  subgraph cluster_irene {
    label="wb-mqtt-voice (Irene) — sister project"; fontsize=12; color="#cfcfcf"; style=rounded; margin=12;
    irene [label="Irene satellite\n• pulls catalog at startup\n• subscribes to bridge/catalog/version\n• sends canonical actions on utterance",
           fillcolor="#e3f2fd", color="#1976d2"];
  }

  // --- the planned setup page ---
  page [label="Voice-setup page (planned)\n/setup/voice  (admin shell)\n• catalog version + last-Irene-fetch indicator\n• per-room voice satellite status\n• test-utterance flow (issues canonical via #18-style probe)\n• 6-code error explorer\n• locale coverage per device + scenario",
        fillcolor="#e3f2fd", color="#1976d2", width=4.8, style="filled,rounded,dashed"];

  // --- broker between bridge and Irene ---
  broker [label="MQTT broker",
          fillcolor="#fff3e0", color="#ef6c00", shape=hexagon, penwidth=2];

  // edges
  pill_a -> irene [label="POST canonical", color="#1976d2"];
  pill_b -> irene [label="GET catalog", color="#1976d2"];
  pill_b -> broker [label="publish version", color="#ef6c00"];
  broker -> irene  [label="refresh nudge", style=dashed, color="#1976d2"];
  pill_c -> pill_b [style=dotted, color="#bdbdbd", label="devices\nlanding in"];
  pending -> pill_c [style=dotted, color="#f57f17", label="completes"];

  // setup page consumes both sides
  page -> pill_b [style=dashed, color="#1976d2", label="read"];
  page -> pill_a [style=dashed, color="#1976d2", label="test"];
  page -> broker [style=dashed, color="#1976d2", label="watch"];

  {rank=same; pill_a; pill_b; pill_c}
}
