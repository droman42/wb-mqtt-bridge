// wb-mqtt-bridge — MQTT integration with Wirenboard. Render:
//   dot -Tpng docs/images/mqtt-integration.dot -o docs/images/mqtt-integration.png
// Palette: see hexagon.dot header.
digraph mqtt_integration {
  rankdir=LR;
  bgcolor="white";
  splines=spline;
  nodesep=0.45; ranksep=1.1;
  fontname="Helvetica"; labelloc=t; fontsize=16;
  label="wb-mqtt-bridge — MQTT integration: virtual-device emulation + WB-passthrough mirroring";

  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  // --- left: the bridge (driven side) ---
  subgraph cluster_bridge {
    label="wb-mqtt-bridge"; fontsize=12; color="#cfcfcf"; style=rounded; margin=12;
    drivers [label="device drivers\n(native / IR / WB-passthrough)", fillcolor="#f3e5f5", color="#7b1fa2"];
    wbsvc   [label="WBVirtualDeviceService\n(infrastructure/wb_device)", fillcolor="#f3e5f5", color="#7b1fa2"];
    mqttcli [label="MQTTClient (aiomqtt)\nMessageBusPort impl", fillcolor="#f3e5f5", color="#7b1fa2"];
  }

  // --- center: the MQTT broker ---
  broker [label="MQTT broker\n(mosquitto on the Wirenboard 7)", fillcolor="#fff3e0", color="#ef6c00",
          shape=hexagon, penwidth=2, fontsize=12, width=3.6];

  // --- right: what else is on the broker ---
  subgraph cluster_wb {
    label="Wirenboard ecosystem"; fontsize=12; color="#cfcfcf"; style=rounded; margin=12;
    wbserial [label="wb-mqtt-serial\nowns native WB controls\n(wb-mr6c / wb-mdm3 / wb-mrgbw-d /\ndooya / wb-gpio / hvac_* …)",
              fillcolor="#e3f2fd", color="#1976d2"];
    wbrules  [label="wb-rules\nautomation engine\nreads value topics from BOTH\nnative WB and the bridge",
              fillcolor="#e3f2fd", color="#1976d2"];
    wbui     [label="WB native UI\nlists every published\nvirtual device",
              fillcolor="#e3f2fd", color="#1976d2"];
  }

  // --- topics legend (data note) ---
  topics [shape=note, fillcolor="#fff8e1", color="#f57f17", fontsize=10,
          label="WB MQTT convention\n──────────────────────────\n/devices/{dev}/meta                       (retained, JSON: name + driver)\n/devices/{dev}/controls/{ctrl}/meta       (retained, JSON: type / order / units)\n/devices/{dev}/controls/{ctrl}            (retained, value)\n/devices/{dev}/controls/{ctrl}/on         (command — write to control)\n/devices/{dev}/controls/{ctrl}/meta/error (r / w / p error codes)"];

  // --- the two-way flow ---
  // Bridge publishes its own virtual devices:
  drivers  -> wbsvc   [label="state change", color="#7b1fa2"];
  wbsvc    -> mqttcli [label="publish meta + value", color="#7b1fa2"];
  mqttcli  -> broker  [label="bridge devices as\nWB virtual devices\n(retained)", color="#7b1fa2"];

  // Bridge subscribes for WB-passthrough mirroring + driver-specific topics:
  mqttcli -> broker [label="subscribe\n  /devices/<wb>/controls/<c>\n  /devices/<wb>/controls/<c>/meta/error", dir=back, color="#7b1fa2", style=dashed];
  drivers -> mqttcli [label="WB-passthrough write\n→ /devices/<wb>/controls/<c>/on\nIR driver publish\n→ wb-msw-v3 IR code topic", color="#7b1fa2", style=dashed];

  // WB side
  wbserial -> broker [label="value topics\n(native controls)", color="#1976d2"];
  broker   -> wbrules [label="subscribes to all\nrelevant topics", color="#1976d2", style=dashed];
  broker   -> wbui    [label="lists\n/devices/{*}/meta", color="#1976d2", style=dashed];

  // legend hangs off the broker
  broker -> topics [style=invis];

  {rank=same; wbsvc; mqttcli}
  {rank=same; wbserial; wbrules; wbui}
}
