// wb-mqtt-bridge — REST + SSE surface organised by router. Render:
//   dot -Tpng docs/images/rest-surface.dot -o docs/images/rest-surface.png
// Palette: see hexagon.dot header.
digraph rest_surface {
  rankdir=LR;
  bgcolor="white";
  splines=spline;
  nodesep=0.35; ranksep=0.7;
  fontname="Helvetica"; labelloc=t; fontsize=16;
  label="wb-mqtt-bridge — REST + SSE surface (presentation/api/routers/)";

  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  // --- consumer side ---
  client [label="UI · CLI · voice (Irene)\n· third-party · curl",
          fillcolor="#f5f5f5", color="#757575", shape=box, width=2.4];

  // --- the routers ---
  system [shape=note, fillcolor="#e3f2fd", color="#1976d2",
          label="system.py\nGET  /\nGET  /system\nGET  /config/system\nGET  /system/catalog\nPOST /reload"];

  devices [shape=note, fillcolor="#e3f2fd", color="#1976d2",
           label="devices.py\nGET  /config/device/{id}\nGET  /config/devices\nPOST /devices/{id}/action\nGET  /devices/{id}/layout"];

  scenarios [shape=note, fillcolor="#e3f2fd", color="#1976d2",
             label="scenarios.py\nGET  /scenario/definition\nGET  /scenario/definition/{id}\nGET  /scenario/{id}/layout\nPOST /scenario/start\nPOST /scenario/switch\nPOST /scenario/shutdown\nPOST /scenario/role_action"];

  rooms [shape=note, fillcolor="#e3f2fd", color="#1976d2",
         label="rooms.py\nGET /room/list\nGET /room/{id}"];

  state [shape=note, fillcolor="#e3f2fd", color="#1976d2",
         label="state.py\nGET /devices/{id}/state\nGET /devices/{id}/persisted_state\nGET /devices/persisted_states\nGET /scenario/state\nGET /scenario/{id}/state"];

  events [shape=note, fillcolor="#e3f2fd", color="#1976d2",
          label="events.py  (SSE)\nGET  /events/devices\nGET  /events/scenarios\nGET  /events/system\nGET  /events/stats\nPOST /events/test"];

  mqtt [shape=note, fillcolor="#e3f2fd", color="#1976d2",
        label="mqtt.py\nPOST /publish\n(escape hatch — arbitrary publish)"];

  // --- where each router lands behind the port ---
  devmgr   [label="DeviceManager", fillcolor="#fff3e0", color="#ef6c00"];
  scnmgr   [label="ScenarioManager", fillcolor="#fff3e0", color="#ef6c00"];
  roommgr  [label="RoomManager", fillcolor="#fff3e0", color="#ef6c00"];
  store    [label="StateRepositoryPort", fillcolor="#f3e5f5", color="#7b1fa2"];
  ssemgr   [label="SSEManager\n(EventPublisherPort)", fillcolor="#e3f2fd", color="#1976d2"];
  mqttcli  [label="MessageBusPort\n(MQTTClient)", fillcolor="#f3e5f5", color="#7b1fa2"];

  // edges: client uses routers; routers call into managers / store / SSE
  client -> system;
  client -> devices;
  client -> scenarios;
  client -> rooms;
  client -> state;
  client -> events;
  client -> mqtt;

  system   -> devmgr     [style=dashed];
  devices  -> devmgr     [style=dashed];
  devices  -> store      [style=dashed];
  scenarios -> scnmgr    [style=dashed];
  rooms    -> roommgr    [style=dashed];
  state    -> devmgr     [style=dashed];
  state    -> scnmgr     [style=dashed];
  state    -> store      [style=dashed];
  events   -> ssemgr     [style=dashed];
  mqtt     -> mqttcli    [style=dashed];

  {rank=same; system; devices; scenarios; rooms; state; events; mqtt}
  {rank=sink; devmgr; scnmgr; roommgr; store; ssemgr; mqttcli}
}
