// wb-mqtt-bridge — planned topology-setup flow. Render:
//   dot -Tpng docs/images/topology-setup-flow.dot -o docs/images/topology-setup-flow.png
// Palette: see hexagon.dot header.
digraph topology_setup {
  rankdir=LR;
  bgcolor="white";
  splines=spline;
  nodesep=0.45; ranksep=0.9;
  fontname="Helvetica"; labelloc=t; fontsize=16;
  label="wb-mqtt-bridge — planned topology-setup flow (Claude wiring-interview today, graph editor tomorrow)";

  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  // --- known devices (from DeviceManager) feed the editor with available nodes ---
  devmgr [shape=note, fillcolor="#fff8e1", color="#f57f17",
          label="DeviceManager.devices\n+ each device's capability map\n(ports / inputs / outputs the device exposes)"];

  // --- the planned page ---
  page [label="Topology-setup page (planned)\n• graph editor — nodes + edges + ordering edges\n• drag devices in from a palette\n• declare manual nodes (RCA hubs, tape decks, …)\n• carries: video / audio / arc per link\n• path-preview — DFS source → display → audio\n• validator — referenced devices exist, no cycles,\n  sink ports resolve to declared inputs",
        fillcolor="#e3f2fd", color="#1976d2", width=4.8, style="filled,rounded,dashed"];

  // --- user review ---
  user [label="user reviews\n+ commits",
        fillcolor="#fff3e0", color="#ef6c00"];

  // --- output ---
  cfg [shape=note, fillcolor="#fff8e1", color="#f57f17",
       label="backend/config/topology.json\n──────────────────────────\nnodes (manual)  ·  links  ·  ordering\nthe typed Topology the bridge already consumes"];

  // --- today's flow as a faded parallel ---
  interview [label="TODAY: Claude wiring-interview\nuser describes the rack →\nassistant proposes nodes + links + ordering →\nuser corrects → assistant writes topology.json",
             fillcolor="#f5f5f5", color="#757575", style="filled,rounded,dashed"];

  schema_doc [shape=note, fillcolor="#fff8e1", color="#f57f17",
              label="design ref:\ndocs/design/scenarios/scenario_system_redesign.md §4\nschema · semantics · validation rules"];

  // edges
  devmgr -> page [color="#1976d2", label="palette\nof available\nnodes"];
  page -> user;
  user -> cfg;

  // today's flow
  interview -> cfg [style=dashed, color="#bdbdbd", label="hand-written"];
  schema_doc -> interview [style=dotted, color="#f57f17"];
  schema_doc -> page      [style=dotted, color="#f57f17", label="conformed to"];

  {rank=same; devmgr; interview}
  {rank=same; page; schema_doc}
}
