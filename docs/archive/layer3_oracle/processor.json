  "stateInterface": {
    "interfaceName": "EMotivaXMC2State",
    "fields": [
      {
        "name": "power",
        "type": "string | null",
        "optional": true,
        "description": "Processor power state (\"on\", \"off\", or null)"
      },
      {
        "name": "zone2_power",
        "type": "string | null",
        "optional": true,
        "description": "Zone 2 power state (\"on\", \"off\", or null)"
      },
      {
        "name": "volume",
        "type": "number | null",
        "optional": true,
        "description": "Main zone volume level"
      },
      {
        "name": "zone2_volume",
        "type": "number | null",
        "optional": true,
        "description": "Zone 2 volume level"
      },
      {
        "name": "input_source",
        "type": "string | null",
        "optional": true,
        "description": "Main zone input source"
      },
      {
        "name": "connected",
        "type": "boolean",
        "optional": true,
        "description": "Device connection status"
      },
      {
        "name": "mute",
        "type": "boolean | null",
        "optional": true,
        "description": "Main zone mute status"
      },
      {
        "name": "zone2_mute",
        "type": "boolean | null",
        "optional": true,
        "description": "Zone 2 mute status"
      }
    ],
    "imports": [
      "BaseDeviceState"
    ],
    "extends": [
      "BaseDeviceState"
    ]
  },
  "actionHandlers": [
    {
      "actionName": "power_on",
      "handlerCode": "\n        executeAction.mutate({ \n          deviceId: 'processor', \n          action: { action: 'power_on', params: payload } \n        });\n      ",
      "dependencies": [
        "useExecuteDeviceAction"
      ]
    },
    {
      "actionName": "power_off",
      "handlerCode": "\n        executeAction.mutate({ \n          deviceId: 'processor', \n          action: { action: 'power_off', params: payload } \n        });\n      ",
      "dependencies": [
        "useExecuteDeviceAction"
      ]
    },
    {
      "actionName": "set_input",
      "handlerCode": "\n        executeAction.mutate({ \n          deviceId: 'processor', \n          action: { action: 'set_input', params: payload } \n        });\n      ",
      "dependencies": [
        "useExecuteDeviceAction"
      ]
    },
    {
      "actionName": "set_volume",
      "handlerCode": "\n        executeAction.mutate({ \n          deviceId: 'processor', \n          action: { action: 'set_volume', params: payload } \n        });\n      ",
