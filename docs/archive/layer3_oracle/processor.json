        "useExecuteDeviceAction"
      ]
    },
    {
      "actionName": "get_available_inputs",
      "handlerCode": "\n        executeAction.mutate({ \n          deviceId: 'processor', \n          action: { action: 'get_available_inputs', params: payload } \n        });\n      ",
      "dependencies": [
        "useExecuteDeviceAction"
      ]
    }
