{
  "repo": "locveil-bridge",
  "roots": [
    "README.md",
    "CONTRIBUTING.md",
    "backend/README.md",
    "ui/README.md",
    "eval/README.md",
    "ops/INSTALL.md",
    "docs/QUICKSTART.md",
    "docs/architecture",
    "docs/guides",
    "docs/images",
    "contracts/README.md",
    "contracts/catalog/README.md",
    "contracts/device-integration/README.md",
    "contracts/docs-manifest/README.md"
  ],
  "surfaces": {
    "rest-api": ["backend/src/locveil_bridge/presentation/**"],
    "catalog": ["contracts/catalog/**", "backend/src/locveil_bridge/presentation/api/catalog.py"],
    "device-integration": ["contracts/device-integration/**"],
    "drivers": ["backend/src/locveil_bridge/infrastructure/devices/**", "backend/src/locveil_bridge/domain/devices/**"],
    "scenarios": ["backend/src/locveil_bridge/domain/scenarios/**", "config/scenarios/**", "config/topology.json"],
    "config": ["config/**", "backend/src/locveil_bridge/infrastructure/config/**"],
    "ui": ["ui/src/**"],
    "mqtt": ["backend/src/locveil_bridge/infrastructure/mqtt/**", "backend/src/locveil_bridge/infrastructure/wb_device/**", "wb-rules/**"],
    "reports": ["backend/src/locveil_bridge/domain/reports/**", "contracts/pins/report-protocol/**"],
    "deployment": ["ops/**", ".github/workflows/**", "backend/Dockerfile", "ui/Dockerfile"]
  },
  "nodes": [
    { "id": "readme", "path": "README.md", "class": "front-door",
      "audience": ["operator", "tester", "integrator", "contributor"],
      "covers": ["deployment", "rest-api"], "status": "banner",
      "note": "status banner: deployed on the WB7 since v0.6.0" },
    { "id": "contributing", "path": "CONTRIBUTING.md", "class": "contributor",
      "audience": ["contributor"],
      "covers": ["deployment", "catalog", "rest-api"], "status": "ok" },
    { "id": "backend-readme", "path": "backend/README.md", "class": "contributor",
      "audience": ["contributor", "tester"],
      "covers": ["drivers", "rest-api"], "status": "ok" },
    { "id": "ui-readme", "path": "ui/README.md", "class": "contributor",
      "audience": ["contributor"],
      "covers": ["ui"], "status": "ok" },
    { "id": "eval-readme", "path": "eval/README.md", "class": "contributor",
      "audience": ["contributor", "tester"], "status": "ok",
      "note": "test execution logic lives in locveil-commons/eval; this README is the local front door" },
    { "id": "install", "path": "ops/INSTALL.md", "class": "operator",
      "audience": ["operator"],
      "covers": ["deployment"], "status": "ok" },
    { "id": "quickstart", "path": "docs/QUICKSTART.md", "class": "quickstart",
      "audience": ["tester"],
      "covers": ["catalog", "rest-api"], "status": "ok",
      "note": "safe by construction — never points at the live house broker" },
    { "id": "arch/overview", "path": "docs/architecture/overview.md", "class": "narrative",
      "audience": ["tester", "integrator", "contributor"],
      "covers": ["rest-api", "drivers", "mqtt"], "status": "ok", "diagram": "hexagon" },
    { "id": "arch/key-concepts", "path": "docs/architecture/key-concepts.md", "class": "narrative",
      "audience": ["tester", "integrator", "contributor"],
      "covers": ["config", "scenarios", "drivers"], "status": "ok" },
    { "id": "arch/interfaces", "path": "docs/architecture/interfaces.md", "class": "narrative",
      "audience": ["integrator", "contributor"],
      "covers": ["rest-api", "mqtt"], "status": "ok", "diagram": "rest-surface" },
    { "id": "arch/devices-and-scenarios", "path": "docs/architecture/devices-and-scenarios.md", "class": "narrative",
      "audience": ["tester", "integrator", "contributor"],
      "covers": ["drivers", "scenarios"], "status": "ok", "diagram": "scenario-lifecycle" },
    { "id": "arch/rooms", "path": "docs/architecture/rooms.md", "class": "narrative",
      "audience": ["integrator", "contributor"],
      "covers": ["config"], "status": "ok", "diagram": "room-membership" },
    { "id": "arch/ui", "path": "docs/architecture/ui.md", "class": "narrative",
      "audience": ["contributor"],
      "covers": ["ui"], "status": "ok", "diagram": "ui-architecture" },
    { "id": "howto/new-device", "path": "docs/guides/howto-new-device.md", "class": "howto",
      "audience": ["integrator", "contributor"],
      "covers": ["config", "drivers"], "status": "ok" },
    { "id": "howto/new-driver", "path": "docs/guides/howto-new-driver.md", "class": "howto",
      "audience": ["contributor"],
      "covers": ["drivers"], "status": "ok" },
    { "id": "howto/new-scenario", "path": "docs/guides/howto-new-scenario.md", "class": "howto",
      "audience": ["integrator", "contributor"],
      "covers": ["scenarios"], "status": "ok" },
    { "id": "report-a-problem", "path": "docs/guides/report-a-problem.md", "class": "end-user",
      "audience": ["end-user", "operator"],
      "covers": ["reports"], "status": "ok" },
    { "id": "contracts-registry", "path": "contracts/README.md", "class": "contributor",
      "audience": ["integrator", "contributor"],
      "covers": ["catalog", "device-integration", "reports"], "status": "ok" },
    { "id": "contract/catalog", "path": "contracts/catalog/README.md", "class": "canonical-reference",
      "audience": ["integrator"],
      "covers": ["catalog"], "status": "ok",
      "canonical": { "invariant": "cross-repo-source-of-truth",
                     "stamp": "contracts/catalog/STAMP.json",
                     "guard": "backend/tests/unit/test_contracts_golden.py" } },
    { "id": "contract/device-integration", "path": "contracts/device-integration/README.md", "class": "canonical-reference",
      "audience": ["integrator"],
      "covers": ["device-integration"], "status": "ok",
      "canonical": { "invariant": "cross-repo-source-of-truth",
                     "stamp": "contracts/device-integration/STAMP.json",
                     "guard": "backend/tests/unit/test_device_integration_schema.py" } },
    { "id": "contract/docs-manifest", "path": "contracts/docs-manifest/README.md", "class": "contributor",
      "audience": ["contributor"], "status": "ok",
      "note": "pointer README for the manifest's own stamp (INTERNAL contract)" },
    { "id": "diagram/hexagon", "path": "docs/images/hexagon.dot", "class": "diagram",
      "audience": ["contributor"], "covers": ["rest-api", "drivers"], "status": "ok" },
    { "id": "diagram/rest-surface", "path": "docs/images/rest-surface.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["rest-api"], "status": "ok" },
    { "id": "diagram/ui-architecture", "path": "docs/images/ui-architecture.dot", "class": "diagram",
      "audience": ["contributor"], "covers": ["ui"], "status": "ok" },
    { "id": "diagram/appliance-pages", "path": "docs/images/appliance-pages.dot", "class": "diagram",
      "audience": ["contributor"], "covers": ["ui"], "status": "ok" },
    { "id": "diagram/layout-manifest", "path": "docs/images/layout-manifest.dot", "class": "diagram",
      "audience": ["contributor"], "covers": ["ui", "rest-api"], "status": "ok" },
    { "id": "diagram/driver-flavors", "path": "docs/images/driver-flavors.dot", "class": "diagram",
      "audience": ["contributor"], "covers": ["drivers"], "status": "ok" },
    { "id": "diagram/device-setup-flow", "path": "docs/images/device-setup-flow.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["config", "drivers"], "status": "ok" },
    { "id": "diagram/mqtt-integration", "path": "docs/images/mqtt-integration.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["mqtt"], "status": "ok" },
    { "id": "diagram/scenario-lifecycle", "path": "docs/images/scenario-lifecycle.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["scenarios"], "status": "ok" },
    { "id": "diagram/scenario-reconciler", "path": "docs/images/scenario-reconciler.dot", "class": "diagram",
      "audience": ["contributor"], "covers": ["scenarios"], "status": "ok" },
    { "id": "diagram/declarative-composition", "path": "docs/images/declarative-composition.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["scenarios", "config"], "status": "ok" },
    { "id": "diagram/room-membership", "path": "docs/images/room-membership.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["config"], "status": "ok" },
    { "id": "diagram/rooms-in-use", "path": "docs/images/rooms-in-use.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["config"], "status": "ok" },
    { "id": "diagram/topology-setup-flow", "path": "docs/images/topology-setup-flow.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["scenarios", "config"], "status": "ok" },
    { "id": "diagram/voice-setup", "path": "docs/images/voice-setup.dot", "class": "diagram",
      "audience": ["integrator"], "covers": ["catalog"], "status": "ok" }
  ]
}
